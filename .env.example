OFOX_API_KEY=replace_with_ofox_api_key
OFOX_DISABLE_PROXY=1

APP_SESSION_SECRET=replace_with_long_random_secret
ACCESS_USERNAME=admin
ACCESS_PASSWORD=replace_with_admin_password

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=ai_user
MYSQL_PASSWORD=ai_user_123456
MYSQL_DATABASE=ai_mid_platform

# =========================
# 并发与队列配置
# =========================
# 后台生成任务并发数：图片生成、PPT、Word、Excel 等文件生成共用这个池子。
# 例如设置为 10，表示最多同时处理 10 个生成任务；第 11 个会提交成功并排队等待。
# 生产环境建议结合模型接口限流和机器配置压测后调整。
TASK_WORKER_CONCURRENCY=10

# worker 没拿到任务时的轮询间隔，越小响应越快，但数据库查询更频繁。
TASK_POLL_INTERVAL_SECONDS=1.5

# 运行中的任务如果超过这个秒数仍未更新，服务启动时会重新放回队列。
TASK_RUNNING_REQUEUE_SECONDS=3600

# =========================
# 文本模型输出配置
# =========================
TEXT_TEMPERATURE=0.7
TEXT_MAX_OUTPUT_TOKENS=4096
RESPONSES_MAX_OUTPUT_TOKENS=4096
GEMINI_MAX_OUTPUT_TOKENS=4096

# =========================
# MySQL 连接池配置
# =========================
# 常驻数据库连接数。要大于等于任务并发数，并给接口请求留余量。
DB_POOL_SIZE=50

# 连接池满了以后允许临时额外开的连接数。
DB_MAX_OVERFLOW=100

# 等待数据库连接的最长秒数；超过后请求会报连接池超时。
DB_POOL_TIMEOUT_SECONDS=30

OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET=
OSS_PUBLIC_BASE_URL=
OSS_UPLOAD_PREFIX=

RAG_BASE_URL=http://121.43.112.129:3001
