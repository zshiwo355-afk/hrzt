# 需在 http { } 内被 include（如 sites-enabled），以便下方 map 生效。
# 长对话 / 慢首包时需放大 proxy_*_timeout；否则默认约 60s 会 504。
# WebSocket（若仍使用）需转发 Upgrade；文本流式已改为 SSE：/api/chat/stream
# 长对话 / 慢首包时需放大 proxy_*_timeout；SSE 建议关闭 buffering。

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    server_name huairenai888.com www.huairenai888.com;

    client_max_body_size 2G;

    location ^~ /api/chat/stream {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 75s;
        proxy_send_timeout 600s;
        proxy_read_timeout 600s;
        proxy_buffering off;
        proxy_cache off;
    }

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 75s;
        proxy_send_timeout 600s;
        proxy_read_timeout 600s;

        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/huairenai888.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/huairenai888.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = www.huairenai888.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    if ($host = huairenai888.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name huairenai888.com www.huairenai888.com;
    return 404; # managed by Certbot
}
